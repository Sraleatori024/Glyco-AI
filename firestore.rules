rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if the user has an admin role
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == 'nickinicolas380@gmail.com'); // Secure backup for developer email as first admin
    }

    // Audit logs rules
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Users collection and subcollections rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /profile/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /logs/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /ai_history/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /reports/{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
